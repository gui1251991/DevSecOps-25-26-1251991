pipeline {

    // Executa o pipeline dentro de um container Docker
    agent {
        docker {
            // Usa Gradle com Java 11 (compatível com o projeto)
            image 'gradle:7.4.1-jdk11'
        }
    }

    stages {

        // Obtém o código do repositório
        stage('Checkout') {
            steps {
                git 'https://bitbucket.org/pssmatos/gradle_basic_demo'
            }
        }

        // Compila a aplicação (sem testes)
        stage('Assemble') {
            steps {
                sh './gradlew assemble'
            }
        }

        // Executa os testes unitários
        stage('Test') {
            steps {
                sh './gradlew test'
            }
        }

        // Guarda os artefatos gerados (.jar)
        stage('Archive') {
            steps {
                archiveArtifacts 'build/libs/*.jar'
            }
        }
    }
}