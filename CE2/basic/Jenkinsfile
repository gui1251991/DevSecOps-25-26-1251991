pipeline {
    agent {
        docker {
            image 'gradle:7.4.2-jdk11'
        }
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Java Version') {
            steps {
                dir('CE2/basic') {
                    sh 'java -version'
                    sh 'chmod +x gradlew'
                    sh './gradlew --version'
                }
            }
        }

        stage('Assemble') {
            steps {
                dir('CE2/basic') {
                    sh './gradlew assemble'
                }
            }
        }

        stage('Test') {
            steps {
                dir('CE2/basic') {
                    sh './gradlew test'
                }
            }
        }

        stage('Javadoc') {
            steps {
                dir('CE2/basic') {
                    sh './gradlew javadoc'
                }
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'CE2/basic/build/libs/*.war', fingerprint: true
                archiveArtifacts artifacts: 'CE2/basic/build/docs/javadoc/**', fingerprint: true
            }
        }
    }
}